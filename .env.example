# =============================================================
# Backend (apps/api)
# =============================================================
NODE_ENV=development
PORT=3000

# PostgreSQL local (proyecto compartido en 5433)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/genograma

# JWT
JWT_SECRET=change-me-please-min-32-chars-abcdef
JWT_REFRESH_SECRET=change-me-too-different-secret-abcd
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Cookies
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# CORS - origenes permitidos (separados por coma)
CORS_ORIGINS=http://localhost:5173

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Genograma <no-reply@example.com>"

# Storage
STORAGE_DIR=./storage

# =============================================================
# Frontend (apps/web) - prefijo VITE_ obligatorio
# =============================================================
VITE_API_BASE_URL=http://localhost:3000
VITE_GOOGLE_CLIENT_ID=
