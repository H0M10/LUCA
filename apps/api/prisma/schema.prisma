generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model allergy {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  person_id  String   @db.Uuid
  kind       String
  name       String
  severity   String?
  notes      String?
  created_at DateTime @default(now()) @db.Timestamptz(6)
  person     person   @relation(fields: [person_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([person_id], map: "idx_allergy_person")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model app_user {
  id                                                       String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                                                    String             @unique @db.Citext
  password_hash                                            String?
  full_name                                                String
  avatar_media_id                                          String?            @db.Uuid
  birth_date                                               DateTime?          @db.Date
  gender                                                   String?
  role                                                     String             @default("user")
  status                                                   String             @default("active")
  email_verified_at                                        DateTime?          @db.Timestamptz(6)
  last_login_at                                            DateTime?          @db.Timestamptz(6)
  locale                                                   String?            @default("es")
  created_at                                               DateTime           @default(now()) @db.Timestamptz(6)
  updated_at                                               DateTime           @default(now()) @db.Timestamptz(6)
  deleted_at                                               DateTime?          @db.Timestamptz(6)
  media_app_user_avatar_media_idTomedia                    media?             @relation("app_user_avatar_media_idTomedia", fields: [avatar_media_id], references: [id], onUpdate: NoAction, map: "fk_app_user_avatar")
  audit_log                                                audit_log[]
  auth_token                                               auth_token[]
  broadcast                                                broadcast[]
  content_report_content_report_reporter_user_idToapp_user content_report[]   @relation("content_report_reporter_user_idToapp_user")
  content_report_content_report_resolved_byToapp_user      content_report[]   @relation("content_report_resolved_byToapp_user")
  feature_flag                                             feature_flag[]
  ip_block                                                 ip_block[]
  login_attempt                                            login_attempt[]
  media_media_owner_user_idToapp_user                      media[]            @relation("media_owner_user_idToapp_user")
  notification                                             notification[]
  oauth_account                                            oauth_account[]
  refresh_token                                            refresh_token[]
  share_link                                               share_link[]
  totp_backup_code                                         totp_backup_code[]
  totp_secret                                              totp_secret?
  tree                                                     tree[]
  tree_member_tree_member_invited_byToapp_user             tree_member[]      @relation("tree_member_invited_byToapp_user")
  tree_member_tree_member_user_idToapp_user                tree_member[]      @relation("tree_member_user_idToapp_user")
}

model audit_log {
  id          BigInt    @id @default(autoincrement())
  user_id     String?   @db.Uuid
  tree_id     String?   @db.Uuid
  entity_type String
  entity_id   String?   @db.Uuid
  action      String
  diff        Json?
  ip          String?   @db.Inet
  user_agent  String?
  created_at  DateTime  @default(now()) @db.Timestamptz(6)
  tree        tree?     @relation(fields: [tree_id], references: [id], onUpdate: NoAction)
  app_user    app_user? @relation(fields: [user_id], references: [id], onUpdate: NoAction)

  @@index([entity_type, entity_id], map: "idx_audit_log_entity")
  @@index([tree_id, created_at(sort: Desc)], map: "idx_audit_log_tree_time")
  @@index([user_id, created_at(sort: Desc)], map: "idx_audit_log_user_time")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model auth_token {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String?   @db.Uuid
  purpose    String
  token_hash String    @unique
  payload    Json?
  expires_at DateTime  @db.Timestamptz(6)
  used_at    DateTime? @db.Timestamptz(6)
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  app_user   app_user? @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([expires_at], map: "idx_auth_token_expires")
  @@index([user_id, purpose], map: "idx_auth_token_user_purpose")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model broadcast {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title        String
  body         String
  channel      String
  scheduled_at DateTime? @db.Timestamptz(6)
  sent_at      DateTime? @db.Timestamptz(6)
  created_by   String    @db.Uuid
  created_at   DateTime  @default(now()) @db.Timestamptz(6)
  app_user     app_user  @relation(fields: [created_by], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model clinical_document {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  person_id  String    @db.Uuid
  media_id   String    @db.Uuid
  title      String
  category   String?
  issued_at  DateTime? @db.Date
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  media      media     @relation(fields: [media_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  person     person    @relation(fields: [person_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([person_id], map: "idx_clinical_document_person")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model content_report {
  id                                                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reporter_user_id                                   String?   @db.Uuid
  entity_type                                        String
  entity_id                                          String    @db.Uuid
  reason                                             String
  status                                             String    @default("pending")
  resolved_by                                        String?   @db.Uuid
  resolved_at                                        DateTime? @db.Timestamptz(6)
  created_at                                         DateTime  @default(now()) @db.Timestamptz(6)
  app_user_content_report_reporter_user_idToapp_user app_user? @relation("content_report_reporter_user_idToapp_user", fields: [reporter_user_id], references: [id], onUpdate: NoAction)
  app_user_content_report_resolved_byToapp_user      app_user? @relation("content_report_resolved_byToapp_user", fields: [resolved_by], references: [id], onUpdate: NoAction)

  @@index([status, created_at(sort: Desc)], map: "idx_content_report_status")
}

model feature_flag {
  key         String    @id
  value       Json
  description String?
  updated_by  String?   @db.Uuid
  updated_at  DateTime  @default(now()) @db.Timestamptz(6)
  app_user    app_user? @relation(fields: [updated_by], references: [id], onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
