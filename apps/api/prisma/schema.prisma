  from_person_id                             String    @db.Uuid
  to_person_id                               String    @db.Uuid
  subtype                                    String?
  is_twin                                    Boolean?  @default(false)
  start_date                                 DateTime? @db.Date
  end_date                                   DateTime? @db.Date
  notes                                      String?
  created_at                                 DateTime  @default(now()) @db.Timestamptz(6)
  person_relationship_from_person_idToperson person    @relation("relationship_from_person_idToperson", fields: [from_person_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  person_relationship_to_person_idToperson   person    @relation("relationship_to_person_idToperson", fields: [to_person_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  tree                                       tree      @relation(fields: [tree_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([tree_id, type, from_person_id, to_person_id])
  @@index([from_person_id], map: "idx_relationship_from")
  @@index([to_person_id], map: "idx_relationship_to")
  @@index([tree_id, type], map: "idx_relationship_tree")
}

