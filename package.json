{
  "name": "genograma",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.3",
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "api:dev": "pnpm --filter @genograma/api dev",
    "web:dev": "pnpm --filter @genograma/web dev",
    "db:pull": "pnpm --filter @genograma/api db:pull",
    "db:generate": "pnpm --filter @genograma/api db:generate",
    "render:build": "pnpm install --frozen-lockfile && pnpm --filter @genograma/shared build && pnpm --filter @genograma/api db:generate && pnpm --filter @genograma/api build"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "prettier": "^3.3.3",
    "@types/node": "^22.9.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@prisma/client", "@prisma/engines", "prisma", "esbuild", "bcrypt"]
  }
}
