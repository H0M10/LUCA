  pregnancy_pregnancy_person_idToperson            pregnancy[]         @relation("pregnancy_person_idToperson")
  relationship_relationship_from_person_idToperson relationship[]      @relation("relationship_from_person_idToperson")
  relationship_relationship_to_person_idToperson   relationship[]      @relation("relationship_to_person_idToperson")

  @@index([tree_id, last_name, first_name], map: "idx_person_name")
